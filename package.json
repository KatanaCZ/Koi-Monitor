    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.6",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.2.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "esbuild": "npm:esbuild-wasm@^0.25.12",
